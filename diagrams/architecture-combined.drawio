        <mxCell id="title" value="AI-Driven Database Workload Lab" style="text;html=1;strokeColor=none;fillColor=none;align=left;verticalAlign=middle;whiteSpace=wrap;rounded=0;fontSize=28;fontStyle=1;fontColor=#0F172A" vertex="1" parent="1">
          <mxGeometry x="60" y="36" width="720" height="40" as="geometry" />
        </mxCell>
        <mxCell id="subtitle" value="A developer describes a Postgres workload. The platform translates intent, runs it safely, records telemetry, and summarizes the result." style="text;html=1;strokeColor=none;fillColor=none;align=left;verticalAlign=middle;whiteSpace=wrap;rounded=0;fontSize=13;fontColor=#475569" vertex="1" parent="1">
          <mxGeometry x="60" y="76" width="850" height="24" as="geometry" />
        </mxCell>
        <mxCell id="public-lane" value="PUBLIC EXPERIENCE" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#F8FAFC;strokeColor=#CBD5E1;fontSize=11;fontStyle=1;fontColor=#475569;align=left;verticalAlign=top;spacingLeft=12;spacingTop=8;dashed=1" vertex="1" parent="1">
          <mxGeometry x="60" y="130" width="1080" height="150" as="geometry" />
        </mxCell>
        <mxCell id="private-lane" value="PRIVATE WORKLOAD PLANE" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#F0FDF4;strokeColor=#86EFAC;fontSize=11;fontStyle=1;fontColor=#166534;align=left;verticalAlign=top;spacingLeft=12;spacingTop=8;dashed=1" vertex="1" parent="1">
          <mxGeometry x="60" y="320" width="1080" height="230" as="geometry" />
        </mxCell>
        <mxCell id="ops-lane" value="OPERATIONS AND DELIVERY" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#FFFBEB;strokeColor=#FCD34D;fontSize=11;fontStyle=1;fontColor=#92400E;align=left;verticalAlign=top;spacingLeft=12;spacingTop=8;dashed=1" vertex="1" parent="1">
          <mxGeometry x="60" y="590" width="1080" height="130" as="geometry" />
        </mxCell>
        <mxCell id="browser" value="Developer Browser&#10;prompt + live results" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FFFFFF;strokeColor=#0F172A;fontSize=13;fontStyle=1;fontColor=#0F172A;strokeWidth=2" vertex="1" parent="1">
          <mxGeometry x="100" y="175" width="170" height="64" as="geometry" />
        </mxCell>
        <mxCell id="ui" value="CloudFront + S3&#10;private static UI&#10;OAC + headers" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#EEF2FF;strokeColor=#6366F1;fontSize=13;fontStyle=1;fontColor=#0F172A;strokeWidth=2" vertex="1" parent="1">
