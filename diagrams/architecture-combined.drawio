        </mxCell>
        <mxCell id="api" value="API Gateway&#10;HTTP API&#10;CORS scoped to UI" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FFF1F2;strokeColor=#F43F5E;fontSize=13;fontStyle=1;fontColor=#0F172A;strokeWidth=2" vertex="1" parent="1">
          <mxGeometry x="650" y="168" width="190" height="78" as="geometry" />
        </mxCell>
        <mxCell id="cors-note" value="Public API in V1&#10;CORS is not authentication" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FFFFFF;strokeColor=#CBD5E1;fontSize=11;fontColor=#475569" vertex="1" parent="1">
          <mxGeometry x="910" y="175" width="170" height="62" as="geometry" />
        </mxCell>
        <mxCell id="lambda" value="Lambda API + Worker&#10;FastAPI, Mangum, Python 3.12 arm64&#10;validates Bedrock output and executes capped runs" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FFF7ED;strokeColor=#F97316;fontSize=13;fontStyle=1;fontColor=#0F172A;strokeWidth=2" vertex="1" parent="1">
          <mxGeometry x="105" y="390" width="260" height="92" as="geometry" />
        </mxCell>
        <mxCell id="aurora" value="Aurora Serverless v2&#10;Postgres 15.17, private subnets&#10;0.5-4 ACU workload target" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FDF4FF;strokeColor=#C026D3;fontSize=13;fontStyle=1;fontColor=#0F172A;strokeWidth=2" vertex="1" parent="1">
          <mxGeometry x="470" y="390" width="245" height="92" as="geometry" />
        </mxCell>
        <mxCell id="managed" value="Managed Service Calls&#10;Bedrock: prompt -&gt; spec, metrics -&gt; summary&#10;DynamoDB: run records + per-second metrics&#10;SSM + Secrets Manager: config and DB credentials" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FAF5FF;strokeColor=#A855F7;fontSize=12;fontStyle=1;fontColor=#0F172A;strokeWidth=2;align=left;verticalAlign=middle;spacingLeft=14" vertex="1" parent="1">
          <mxGeometry x="815" y="370" width="280" height="132" as="geometry" />
        </mxCell>
        <mxCell id="network-note" value="Network posture&#10;Aurora accepts 5432 from Lambda SG only. Lambda reaches AWS APIs over HTTPS through NAT; S3 and DynamoDB use gateway endpoints." style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FFFFFF;strokeColor=#86EFAC;fontSize=11;fontColor=#166534;align=left;verticalAlign=middle;spacingLeft=12" vertex="1" parent="1">
