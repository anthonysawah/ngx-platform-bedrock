  </diagram>
  <diagram name="Simple Product Flow" id="ai-workload-lab-clean-v2">
    <mxGraphModel dx="1200" dy="780" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="1200" pageHeight="780" math="0" shadow="0" background="#FFFFFF">
      <root>
        <mxCell id="0" />
