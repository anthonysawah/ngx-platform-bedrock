        <mxCell id="sec-6" parent="1" style="text;html=1;strokeColor=none;fillColor=none;align=left;verticalAlign=middle;fontSize=9;fontColor=#1A1A1A" value="●  Bedrock output Pydantic-validated" vertex="1">
