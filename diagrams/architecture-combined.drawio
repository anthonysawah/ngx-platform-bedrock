        <mxCell id="sec-7" parent="1" style="text;html=1;strokeColor=none;fillColor=none;align=left;verticalAlign=middle;fontSize=9;fontColor=#1A1A1A" value="●  Encryption at rest on all stores" vertex="1">
          <mxGeometry height="20" width="190" x="288" y="688" as="geometry" />
        </mxCell>
        <mxCell id="sec-8" parent="1" style="text;html=1;strokeColor=none;fillColor=none;align=left;verticalAlign=middle;fontSize=9;fontColor=#1A1A1A" value="●  ARM64, immutable Lambda artifact" vertex="1">
